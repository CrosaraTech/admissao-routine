# Variáveis de ambiente do pipeline local
# Copie pra .env e preencha. NUNCA commitar o .env real.

# Token JWT da API E-plugin Alterdata (eContador)
# Obtenha em: painel Alterdata pack.up → Configurações → Integrações → API E-plugin
ECONTADOR_TOKEN=PREENCHER_JWT_ECONTADOR

# Credenciais OAuth do Gmail, em JSON serializado (uma única linha).
# Como gerar:
#   1. Google Cloud Console → APIs & Services → Credentials → OAuth Client ID
#   2. Ative Gmail API no projeto
#   3. Rode fluxo OAuth uma vez pra gerar tokens
#   4. Cole o JSON aqui numa única linha com as chaves:
#      token, refresh_token, token_uri, client_id, client_secret, scopes
# Scopes necessários:
#   - https://www.googleapis.com/auth/gmail.readonly
#   - https://www.googleapis.com/auth/gmail.modify
#   - https://www.googleapis.com/auth/gmail.send
GMAIL_TOKEN=PREENCHER_JSON_OAUTH_GMAIL

# Chave da API Anthropic (Claude Vision)
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=PREENCHER_CHAVE_ANTHROPIC

# ─── Enrichment via API externa de CPF (opcional) ────────────────────
# Quando configurado, o pipeline tenta preencher nome/nascimento/nomedamae/
# naturalidade via consulta CPF antes de depender só do OCR do Claude.
# Deixe em branco pra desabilitar (default — pipeline degrada graciosamente).
#
# Provedores suportados (a implementar em enrichment.py:_lookup_cpf_<nome>):
#   - serpro       (oficial Receita Federal — exige CNPJ corporativo + contrato)
#   - konsi        (mercado, ~R$0,10/consulta)
#   - directdata   (mercado, ~R$0,05/consulta)
#   - cpfcheck     (mercado)
CPF_LOOKUP_PROVIDER=
CPF_LOOKUP_TOKEN=

# ─── Direct Data — enriquecimento via 3 APIs (R$ 1,24/admissão completa) ─
# Token do painel: https://app.directd.com.br → Marketplace → Configurações.
# APIs usadas: CadastroPessoaFisica (R$0,16), MinisterioTrabalhoPIS (R$0,36),
# TituloLocalVotacao (R$0,72). Skip por economia: se payload já completo,
# não chama. Cache em RAM evita duplicação na mesma sessão.
# Sem token → cliente desabilitado, pipeline degrada graciosamente.
DIRECTDATA_TOKEN=PREENCHER_TOKEN_DIRECTDATA
